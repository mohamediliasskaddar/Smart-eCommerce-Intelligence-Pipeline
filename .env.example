# MinIO Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=smart-ecommerce
MINIO_SECURE=false

# Data path (MinIO will handle remote, local caching still uses this)
DATA_PATH=/app/data

# LLM Configuration
GROQ_API_KEY=
GOOGLE_API_KEY=

# Environment
ENV=production
ENV PYTHONPATH=/app