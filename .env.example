
MINIO_ENDPOINT = minio.storage.svc.cluster.local:9000
MINIO_BUCKET   = smart-ecommerce
MINIO_SECURE   = false
MINIO_ACCESS_KEY = minio
MINIO_SECRET_KEY = minio123

# Data path (MinIO will handle remote, local caching still uses this)
DATA_PATH=/app/data

# LLM Configuration
GROQ_API_KEY=
GOOGLE_API_KEY=

# Environment
ENV=production
ENV PYTHONPATH=/app